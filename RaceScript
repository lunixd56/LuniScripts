-- ============================================================
-- GATE CREATION PHYSICS LOGIC
-- ============================================================
local function getLineInterference(p1, p2, oldPos, newPos)
	local d = (p2.X - p1.X) * (newPos.Z - oldPos.Z) - (p2.Z - p1.Z) * (newPos.X - oldPos.X)
	if math.abs(d) < 0.0001 then return nil, nil end
	local u = ((oldPos.X - p1.X) * (newPos.Z - oldPos.Z) - (oldPos.Z - p1.Z) * (newPos.X - oldPos.X)) / d
	local v = ((p2.X - p1.X) * (oldPos.Z - p1.Z) - (p2.Z - p1.Z) * (oldPos.X - p1.X)) / d
	if u >= 0 and u <= 1 and v >= 0 and v <= 1 then
		local intersectX = p1.X + u * (p2.X - p1.X)
		local intersectZ = p1.Z + u * (p2.Z - p1.Z)
		local s1 = (p2.Z - p1.Z) * (oldPos.X - p1.X) - (p2.X - p1.X) * (oldPos.Z - p1.Z)
		local s2 = (p2.Z - p1.Z) * (newPos.X - p1.X) - (p2.X - p1.X) * (newPos.Z - p1.Z)
		return (s1 > 0 and s2 <= 0) or (s1 <= 0 and s2 > 0), (s1 <= 0)
	end
	return nil, nil
end

local function cleanGate(g)
	if g.part then g.part:Destroy(); g.part = nil end
	if g.preview then g.preview:Destroy(); g.preview = nil end
	g.p1, g.p2 = nil, nil
end

local function renderGateVisual(g, color, labelText)
	if g.part then g.part:Destroy() end
	if not g.p1 or not g.p2 then return end

	local mid = (g.p1 + g.p2) / 2
	local dist = (g.p1 - g.p2).Magnitude

	local p = Instance.new("Part")
	p.Size = Vector3.new(0.5, LINE_HEIGHT, dist)
	p.CFrame = CFrame.lookAt(mid, g.p2) * CFrame.new(0, LINE_HEIGHT/2, 0)
	p.Anchored, p.CanCollide, p.Transparency = true, false, 0.6
	p.Color, p.Material = color, Enum.Material.Neon
	p.Parent = workspace

	local bb = Instance.new("BillboardGui")
	bb.Size, bb.AlwaysOnTop, bb.ExtentsOffsetWorldSpace = UDim2.new(0,140,0,24), true, Vector3.new(0, (LINE_HEIGHT/2)+1.5, 0)
	bb.Parent = p
	local tl = Instance.new("TextLabel")
	tl.Size, tl.BackgroundTransparency, tl.Text = UDim2.new(1,0,1,0), 1, labelText
	tl.TextColor3, tl.TextSize, tl.Font = Color3.new(1,1,1), 11, Enum.Font.GothamBold
	tl.Parent = bb
	applyStroke(tl, Color3.new(0,0,0), 1.8, 0)

	g.part = p
end

local function cancelPlacing()
	if clickConn then clickConn:Disconnect(); clickConn = nil end
	if activeCCGate then
		cleanGate(activeCCGate)
		activeCCGate = nil
	elseif placingGate then
		cleanGate(gates[placingGate])
	end
	placingGate, placingStep = nil, 0
	setStatus("Place gates.", Color3.fromRGB(180,180,200))
end

local function startPlacing(key)
	cancelPlacing()
	placingGate, placingStep = key, 1
	setStatus("Click / Tap world for Point 1 of " .. key:upper(), GATE_COLORS[key] or PURPLE)

	clickConn = UserInputService.InputBegan:Connect(function(input, processed)
		if processed then return end
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			local ray = workspace.CurrentCamera:ScreenPointToRay(input.Position.X, input.Position.Y)
			local raycastResult = workspace:Raycast(ray.Origin, ray.Direction * 1000)
			local hitPos = raycastResult and raycastResult.Position or (ray.Origin + ray.Direction * 50)

			if placingStep == 1 then
				placingStep = 2
				setStatus("Click / Tap world for Point 2", GATE_COLORS[placingGate] or PURPLE)
				if placingGate == "cc" then
					local ng = { part=nil, p1=hitPos, p2=nil, preview=nil }
					table.insert(ccGates, ng)
					activeCCGate = ng
				else
					gates[placingGate].p1 = hitPos
				end
			elseif placingStep == 2 then
				local targetGate = activeCCGate or gates[placingGate]
				targetGate.p2 = hitPos

				if clickConn then clickConn:Disconnect(); clickConn = nil end
				if placingGate == "cc" then
					renderGateVisual(targetGate, GATE_COLORS.cc, GATE_LABELS.cc .. " #" .. #ccGates)
					activeCCGate = nil
				else
					renderGateVisual(targetGate, GATE_COLORS[placingGate], GATE_LABELS[placingGate])
				end

				setStatus("Placed successfully!", Color3.fromRGB(80,220,120))
				placingGate, placingStep = nil, 0
			end
		end
	end)
end

