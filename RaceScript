-- LEADERBOARD UPDATING ENGINE
-- ============================================================
local rowPool = {}
local fastestPool = {}

local function getPlrName(uidStr)
	if playerNicknames[uidStr] and playerNicknames[uidStr] ~= "" then
		return playerNicknames[uidStr]
	end
	local p = Players:GetPlayerByUserId(tonumber(uidStr) or 0)
	return p and p.DisplayName or ("User " .. uidStr)
end

local function refreshLeaderboardVisuals(sortedList)
	for _, r in ipairs(rowPool) do r:Destroy() end
	table.clear(rowPool)

	for index, data in ipairs(sortedList) do
		local row = Instance.new("Frame")
		row.Size, row.BackgroundColor3 = UDim2.new(1,0,0,20), (index%2==0 and Color3.fromRGB(22,22,30) or Color3.fromRGB(16,16,22))
		row.BorderSizePixel, row.LayoutOrder, row.Parent = 0, index, leaderContainer
		table.insert(rowPool, row)

		local displayNick = getPlrName(data.uid)
		local nameLbl = makeLabel(row, string.format("%d. %s", index, displayNick), UDim2.new(0.4,0,1,0), UDim2.new(0,4,0,0), 10, Color3.fromRGB(240,240,240))
		nameLbl.TextXAlignment = Enum.TextXAlignment.Left

		local gapText = "—"
		if index > 1 then
			local leaderData = sortedList[1]
			if gapMode == "leader" then
				if data.lap < leaderData.lap then
					gapText = string.format("-%dL", leaderData.lap - data.lap)
				else
					gapText = string.format("+%.3fs", data.totalTime - leaderData.totalTime)
				end
			else
				local aheadData = sortedList[index-1]
				if data.lap < aheadData.lap then
					gapText = string.format("-%dL", aheadData.lap - data.lap)
				else
					gapText = string.format("+%.3fs", data.totalTime - aheadData.totalTime)
				end
			end
		else
			gapText = qualiActive and "QUALI" or string.format("L%d", data.lap)
		end

		local gapLbl = makeLabel(row, gapText, UDim2.new(0.24,0,1,0), UDim2.new(0.4,0,0,0), 9, Color3.fromRGB(200,200,200))
		gapLbl.TextXAlignment = Enum.TextXAlignment.Right

		local boxTarget = data.targetBoxes or targetBoxes
		local pitCountText = string.format("🔧%d/%d", data.boxes or 0, boxTarget)
		local pitColor = (data.boxes or 0) >= boxTarget and Color3.fromRGB(100,255,100) or Color3.fromRGB(255,230,100)
		if (data.boxes or 0) == 0 then pitColor = Color3.fromRGB(160,160,160) end
		local pitLbl = makeLabel(row, pitCountText, UDim2.new(0.18,0,1,0), UDim2.new(0.65,0,0,0), 9, pitColor)

		local ccCountText = string.format("✂️%d", data.ccs or 0)
		local ccColor = (data.ccs or 0) > 0 and Color3.fromRGB(255,100,100) or Color3.fromRGB(160,160,160)
		local ccLbl = makeLabel(row, ccCountText, UDim2.new(0.14,0,1,0), UDim2.new(0.84,0,0,0), 9, ccColor)

		local rowBtn = Instance.new("TextButton")
		rowBtn.Size, rowBtn.Position, rowBtn.BackgroundTransparency, rowBtn.Text = UDim2.new(1,0,1,0), UDim2.new(0,0,0,0), 1, ""
		rowBtn.Parent = row

		rowBtn.MouseButton1Click:Connect(function()
			local targetPlr = Players:GetPlayerByUserId(tonumber(data.uid) or 0)
			if targetPlr and targetPlr.Character and targetPlr.Character:FindFirstChild("Humanoid") and targetPlr ~= player then
				workspace.CurrentCamera.CameraSubject = targetPlr.Character.Humanoid
				spectatingPlayer = targetPlr
				spectateUI.Text = "Spectating: " .. targetPlr.DisplayName
				spectateUI.Visible = true
			end
		end)

		rowBtn.MouseButton2Click:Connect(function()
			ctxTargetUid = data.uid
			ctxNameLbl.Text = "Editing: " .. displayNick
			ctxNickBox.Text = playerNicknames[data.uid] or ""
			local lim = playerLimits[data.uid]
			ctxSpeedBox.Text = lim and lim.speed and tostring(lim.speed) or ""
			ctxDriftBox.Text = lim and lim.drift and tostring(lim.drift) or ""
			ctxBoxesBox.Text = data.targetBoxes and tostring(data.targetBoxes) or ""
			ctxPopup.Visible = true
		end)
	end
end

local function refreshFastestLapsVisuals(sortedList)
	for _, r in ipairs(fastestPool) do r:Destroy() end
	table.clear(fastestPool)

	local validCount = 0
	for _, data in ipairs(sortedList) do
		if data.bestLap < math.huge then
			validCount = validCount + 1
			local row = Instance.new("Frame")
			row.Size, row.BackgroundColor3 = UDim2.new(1,0,0,18), (validCount%2==0 and Color3.fromRGB(26,18,32) or Color3.fromRGB(18,12,24))
			row.BorderSizePixel, row.LayoutOrder, row.Parent = 0, validCount, fastestContainer
			table.insert(fastestPool, row)

			local displayNick = getPlrName(data.uid)
			local nameLbl = makeLabel(row, string.format("%d. %s", validCount, displayNick), UDim2.new(0.5,0,1,0), UDim2.new(0,4,0,0), 10, Color3.fromRGB(240,220,255))
			nameLbl.TextXAlignment = Enum.TextXAlignment.Left

			local lapStr = formatTime(data.bestLap)
			local timeLbl = makeLabel(row, lapStr, UDim2.new(0.5,-4,1,0), UDim2.new(0.5,0,0,0), 10, purpleColor)
			timeLbl.TextXAlignment = Enum.TextXAlignment.Right

			local rowBtn = Instance.new("TextButton")
			rowBtn.Size, rowBtn.BackgroundTransparency, rowBtn.Text = UDim2.new(1,0,1,0), 1, ""
			rowBtn.Parent = row
			rowBtn.MouseButton1Click:Connect(function()
				addLapsTargetUid = data.uid
				addLapsPlayerLbl.Text = "Target: " .. displayNick
				addLapsInputBox.Text = "1"
				addLapsPopup.Visible = true
			end)
		end
	end
end

-- ============================================================
-- LIVE RENDER OVERHEAD IDENTIFICATION SYSTEM
-- ============================================================
local overheadsCache = {}
local function updateOverheads()
	if not showOverheads then
		for _, tag in pairs(overheadsCache) do tag.Enabled = false end
		return
	end

	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= player and p.Character and p.Character:FindFirstChild("Head") then
			local head = p.Character.Head
			local tag = overheadsCache[p.UserId]
			if not tag or tag.Parent ~= head then
				if tag then tag:Destroy() end
				tag = Instance.new("BillboardGui")
				tag.Size, tag.AlwaysOnTop, tag.ExtentsOffset = UDim2.new(0,160,0,40), true, Vector3.new(0,3,0)
				tag.Parent = head
				overheadsCache[p.UserId] = tag

				local inner = Instance.new("TextLabel", tag)
				inner.Size, inner.BackgroundTransparency = UDim2.new(1,0,1,0), 1
				inner.TextSize, inner.Font = 10, Enum.Font.GothamBold
				applyStroke(inner, Color3.new(0,0,0), 1.5, 0)
			end

			local inner = tag:FindFirstChildOfClass("TextLabel")
			if inner then
				local d = playerData[tostring(p.UserId)]
				local displayNick = playerNicknames[tostring(p.UserId)] or p.DisplayName
				if d then
					local boxTarget = d.targetBoxes or targetBoxes
					inner.Text = string.format("%s\nLap: %d | S%d\n🔧 %d/%d | ✂️ %d", 
						displayNick, d.lap, d.sector, d.boxes or 0, boxTarget, d.ccs or 0)
					inner.TextColor3 = (d.boxes or 0) >= boxTarget and Color3.fromRGB(100,255,100) or Color3.fromRGB(255,220,100)
				else
					inner.Text = displayNick .. "\nNo Data"
					inner.TextColor3 = Color3.fromRGB(200,200,200)
				end
			end
			tag.Enabled = true
		end
	end

	for uid, tag in pairs(overheadsCache) do
		if not Players:GetPlayerByUserId(uid) then
			tag:Destroy()
			overheadsCache[uid] = nil
		end
	end
end

-- ============================================================
-- CORE LOGIC RUNSERVICE COROUTINE LOOP
-- ============================================================
RunService.Heartbeat:Connect(function()
	if placingGate and placingStep == 2 then
		local targetGate = activeCCGate or gates[placingGate]
		if targetGate and targetGate.p1 then
			local ray = workspace.CurrentCamera:ScreenPointToRay(mouse.X, mouse.Y)
			local raycastResult = workspace:Raycast(ray.Origin, ray.Direction * 1000)
			local p2 = raycastResult and raycastResult.Position or (ray.Origin + ray.Direction * 50)

			if targetGate.preview then targetGate.preview:Destroy() end
			local mid = (targetGate.p1 + p2) mid = Vector3.new(mid.X, mid.Y + (LINE_HEIGHT/2), mid.Z)
			local dist = (targetGate.p1 - p2).Magnitude
			local p = Instance.new("Part")
			p.Size, p.Anchored, p.CanCollide, p.Transparency = Vector3.new(0.3, LINE_HEIGHT, dist), true, false, 0.75
			p.Color, p.Material = GATE_COLORS[placingGate] or PURPLE, Enum.Material.Neon
			p.CFrame = CFrame.lookAt((targetGate.p1 + p2)/2, p2) * CFrame.new(0, LINE_HEIGHT/2, 0)
			p.Parent = workspace
			targetGate.preview = p
		end
	end

	local now = time()
	local positions = {}
	for _, p in ipairs(Players:GetPlayers()) do
		if p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
			positions[tostring(p.UserId)] = p.Character.HumanoidRootPart.Position
		end
	end

	if now - lastScan >= SCAN_INTERVAL then
		lastScan = now

		for uidStr, pos in pairs(positions) do
			local d = playerData[uidStr]
			if not d then
				d = {
					uid = uidStr,
					displayName = getPlrName(uidStr),
					lap = 0, sector = 0,
					lastPos = pos,
					currentLapStart = now, totalTime = 0,
					bestLap = math.huge,
					bestS1 = math.huge, bestS2 = math.huge, bestS3 = math.huge,
					lastCrossTime = 0,
					boxes = 0, lastBoxSide = nil, lastBoxCross = 0,
					ccs = 0, ccLastSide = {}, ccLastCross = {},
					lastDriftSetting = 0,
				}
				playerData[uidStr] = d
			end

			local old = d.lastPos
			d.lastPos = pos

			if (pos - old).Magnitude > 0.01 and now - d.lastCrossTime > CROSS_COOLDOWN then
				if gates.start.p1 and gates.start.p2 then
					local cross, side = getLineInterference(gates.start.p1, gates.start.p2, old, pos)
					if cross then
						d.lastCrossTime = now
						if d.sector == 3 then
							local lapTime = now - d.currentLapStart
							d.lap = d.lap + 1
							d.totalTime = d.totalTime + lapTime
							if lapTime < d.bestLap then d.bestLap = lapTime end
							if lapTime < sessionBests.lap then sessionBests.lap = lapTime end

							if uidStr == tostring(player.UserId) then
								lapCount = d.lap
								if not qualiActive and lapCount >= targetLaps and not isFinished then
									isFinished = true
									finishedLabel.Text = string.format("🏁 FINISHED! Total: %s", formatTime(d.totalTime))
								end
								deltaLabel.Text = "Lap Time: " .. string.format("%.3fs", lapTime)
							end
						end
						d.sector = 1
						d.currentLapStart = now
					end
				end

				if gates.s2.p1 and gates.s2.p2 and d.sector == 1 then
					local cross = getLineInterference(gates.s2.p1, gates.s2.p2, old, pos)
					if cross then
						d.lastCrossTime = now
						d.sector = 2
						local s1Time = now - d.currentLapStart
						d.lastS1 = s1Time
						if s1Time < d.bestS1 then d.bestS1 = s1Time end
						if s1Time < sessionBests.s1 then sessionBests.s1 = s1Time end
					end
				end

				if gates.s3.p1 and gates.s3.p2 and d.sector == 2 then
					local cross = getLineInterference(gates.s3.p1, gates.s3.p2, old, pos)
					if cross then
						d.lastCrossTime = now
						d.sector = 3
						local s2Time = now - (d.currentLapStart + (d.lastS1 or 0))
						d.lastS2 = s2Time
						if s2Time < d.bestS2 then d.bestS2 = s2Time end
						if s2Time < sessionBests.s2 then sessionBests.s2 = s2Time end
					end
				end

				if gates.pit.p1 and gates.pit.p2 then
					local cross, side = getLineInterference(gates.pit.p1, gates.pit.p2, old, pos)
					if cross and now - d.lastBoxCross > 1.5 then
						d.lastBoxCross = now
						if d.lastBoxSide == nil then
							d.lastBoxSide = side
						elseif d.lastBoxSide ~= side then
							d.lastBoxSide = nil
							d.boxes = d.boxes + 1
							addLog(d.displayName, "PIT STOP", "#" .. d.boxes)
						end
					end
				end

				if gates.pitExit.p1 and gates.pitExit.p2 then
					local cross, side = getLineInterference(gates.pitExit.p1, gates.pitExit.p2, old, pos)
					if cross and now - d.lastBoxCross > 1.5 then
						d.lastBoxCross = now
						if d.lastBoxSide == nil then
							d.lastBoxSide = side
						elseif d.lastBoxSide ~= side then
							d.lastBoxSide = nil
							d.boxes = d.boxes + 1
							addLog(d.displayName, "PIT STOP (EXIT CROSS)", "#" .. d.boxes)
						end
					end
				end

				for i, ccG in ipairs(ccGates) do
					if ccG.p1 and ccG.p2 then
						local cross, side = getLineInterference(ccG.p1, ccG.p2, old, pos)
						if cross and now - (d.ccLastCross[i] or 0) > 1.5 then
							d.ccLastCross[i] = now
							if d.ccLastSide[i] == nil then
								d.ccLastSide[i] = side
							elseif d.ccLastSide[i] ~= side then
								d.ccLastSide[i] = nil
								d.ccs = d.ccs + 1
								addLog(d.displayName, "CUT CORNER", "Gate #" .. i .. " (Total: " .. d.ccs .. ")")
								if uidStr == tostring(player.UserId) then
									notify("You cut corner gate #" .. i)
								end
							end
						end
					end
				end
			end
		end
		latestSnapshot = playerData
	end

	if qualiActive then
		local rem = qualiEndTime - now
		if rem <= 0 then
			qualiActive = false
			qualiLabel.Text = "QUALIFYING CONCLUDED"
			startQualiBtn.Text = "▶ Start Quali"
			startQualiBtn.BackgroundColor3 = Color3.fromRGB(100,30,160)
		else
			qualiLabel.Text = string.format("QUALIFYING - %02d:%02d", math.floor(rem/60), math.floor(rem%60))
		end
	end

	if now - lastLBRefresh >= 1.0 then
		lastLBRefresh = now

		local list = {}
		for _, d in pairs(latestSnapshot) do table.insert(list, d) end

		table.sort(list, function(a, b)
			if a.lap ~= b.lap then return a.lap > b.lap end
			if a.sector ~= b.sector then return a.sector > b.sector end
			return a.totalTime < b.totalTime
		end)
		refreshLeaderboardVisuals(list)

		local fList = {}
		for _, d in pairs(latestSnapshot) do table.insert(fList, d) end
		table.sort(fList, function(a, b) return a.bestLap < b.bestLap end)
		refreshFastestLapsVisuals(fList)

		updateOverheads()
	end

	do
		for uidStr, data in pairs(playerData) do
			local p = Players:GetPlayerByUserId(tonumber(uidStr) or 0)
			local car = p and p.Character and p.Character:FindFirstChild("HumanoidRootPart")
			if car then
				local speed = car.AssemblyLinearVelocity.Magnitude * 3.6
				local sl = car:FindFirstChild("SpeedLimitValue")
				local dl = car:FindFirstChild("DriftLimitValue")

				local specLim = playerLimits[uidStr] and playerLimits[uidStr].speed or maxSpeedLimit
				local specDrift = playerLimits[uidStr] and playerLimits[uidStr].drift or maxDriftLimit

				local isInsidePit = false
				if gates.pit.p1 and gates.pit.p2 and gates.pitExit.p1 and gates.pitExit.p2 then
					local midPit = (gates.pit.p1 + gates.pit.p2)/2
					local midExit = (gates.pitExit.p1 + gates.pitExit.p2)/2
					local pPos = car.Position
					if (pPos - midPit).Magnitude < 150 and (pPos - midExit).Magnitude > (pPos - midPit).Magnitude then
						isInsidePit = true
					end
				end

				local finalSpeedCap = isInsidePit and math.max(10, specLim + pitSpeedOffset) or specLim

				if sl then
					sl.Text = string.format("Speed Cap: %.1f", finalSpeedCap)
				else
					local labelContainer = car:FindFirstChild("OverheadDisplay")
					if labelContainer and labelContainer:FindFirstChild("SpeedText") then
						sl = labelContainer.SpeedText
					end
				end

				if speed > finalSpeedCap + 5 then
					addLog(data.displayName, "SPEEDING", string.format("%.1f km/h (Cap: %.1f)", speed, finalSpeedCap))
					if uidStr == tostring(player.UserId) then notify("Reduce Speed! Over the limit.") end
				end

				local curDrift = 0
				local back = car.CFrame.LookVector
				local vel = car.AssemblyLinearVelocity
				if vel.Magnitude > 2 then
					local vDir = vel.Unit
					local dot = math.abs(back:Dot(vDir))
					curDrift = 1 - dot
				end

				if curDrift > specDrift + 0.05 and speed > 30 then
					addLog(data.displayName, "ILLEGAL SLIDE", string.format("Drift Angle: %.2f", curDrift))
					if uidStr == tostring(player.UserId) then notify("Illegal handling slide detected!") end
				end

				if now - (data.lastDriftSetting or 0) > 0.5 then
					if dl then
						dl.Text = string.format("Slide: %.2f", curDrift)
					else
						local labelContainer = car:FindFirstChild("OverheadDisplay")
						if labelContainer and labelContainer:FindFirstChild("DriftText") then
							dl = labelContainer.DriftText
						end
					end
					data.lastDriftSetting = now
				end
			else
				if uidStr == tostring(player.UserId) then
					lapLabel.Text = "In Foot"
				end
			end
		end
	end

	do
		local leader = nil
		for _, data in pairs(playerData) do
			if not leader then leader = data
			elseif data.lap > leader.lap then leader = data
			elseif data.lap == leader.lap and data.sector > leader.sector then leader = data
			elseif data.lap == leader.lap and data.sector == leader.sector and data.sectorTime < leader.sectorTime then leader = data
			end
		end
		if leader then
			local secStr = leader.sector==0 and "—" or ("S"..leader.sector)
			lapLabel.Text   = qualiActive and ("Lap: "..leader.lap.."  "..secStr) or string.format("Lap: %d / %d  %s", leader.lap, targetLaps, secStr)
			sectorLabel.Text= "Leader: "..leader.displayName
		end
	end

	if spectatingPlayer then
		local tData = playerData[tostring(spectatingPlayer.UserId)]
		if tData and tData.lastPos then
			-- Logic sync keeps camera tracking target safely
		end
	end
end)
